APP_NAME=Scannr
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stderr
LOG_LEVEL=warning

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync

CHROME_PATH=/usr/bin/chromium
SCANNR_NODE_BINARY=/usr/bin/node
SCANNR_NPM_BINARY=/usr/bin/npm
SCANNR_NODE_MODULES_PATH=/app/node_modules
